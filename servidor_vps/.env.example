# Plantilla de variables para despliegue.
# No usar estos valores literales en produccion.

TFM_SERVER_DATA=/data/server_data

# Login web.
TFM_WEB_USERNAME=admin
TFM_WEB_PASSWORD_HASH=replace_with_hash_generated_by_app_auth

# Cookie de sesion. Generar con:
# python -m app.auth --random-secret
TFM_SESSION_SECRET=replace_with_long_random_secret

# API keys para inference_server, ESP32 y scripts. Se pueden separar varias por coma.
# python -m app.auth --random-secret
TFM_API_KEYS=replace_with_machine_api_key

# En produccion debe estar detras de HTTPS.
TFM_SECURE_COOKIE=true
TFM_SESSION_TTL_SECONDS=14400
TFM_LOGIN_MAX_ATTEMPTS=10
TFM_LOGIN_WINDOW_SECONDS=300

# Limites defensivos.
TFM_MAX_UPLOAD_BYTES=10485760
TFM_MAX_CSV_ROWS=120000

# Buffers live en RAM. Reducen open/write/close por cada POST y hacen flush
# periodico a disco sin aumentar la latencia de respuesta al ESP32/worker.
TFM_SAMPLE_FLUSH_ROWS=100
TFM_SAMPLE_FLUSH_SECONDS=1.0
TFM_RESULT_FLUSH_ROWS=10
TFM_RESULT_FLUSH_SECONDS=1.0
